# Variables d'environnement — copier en .env et adapter
# Aucun secret n'est commité (CON-008, global_rules security)

# Application
GSIE_ENVIRONMENT=development
GSIE_DEBUG=false
GSIE_LOG_LEVEL=INFO

# API
GSIE_API_V1_PREFIX=/api/v1
GSIE_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
# Limite taille corps de requête (bytes) — défaut 1 MiB
GSIE_MAX_REQUEST_BODY_SIZE=1048576

# Rate limiting (OWASP A07)
GSIE_RATE_LIMIT_ENABLED=true
GSIE_RATE_LIMIT_DEFAULT=60/minute
GSIE_RATE_LIMIT_HEALTH=300/minute
GSIE_RATE_LIMIT_EVALUATE=30/minute
# Stockage du rate limiter — Redis en production pour distribution entre workers
# En développement/test, "memory://" évite la dépendance Redis
GSIE_RATE_LIMIT_STORAGE_URL=memory://

# PostgreSQL + PostGIS — secrets à définir dans .env
GSIE_DB_USER=gsie
GSIE_DB_PASSWORD=change-me-in-.env
GSIE_DB_NAME=gsie
GSIE_DATABASE_URL=postgresql+asyncpg://gsie:change-me-in-.env@localhost:5432/gsie
GSIE_DB_POOL_SIZE=5
GSIE_DB_MAX_OVERFLOW=10
GSIE_DB_ECHO=false
GSIE_DB_PGBOUNCER_MODE=false
GSIE_DB_POOL_TIMEOUT=30

# Redis — secret à définir dans .env
GSIE_REDIS_PASSWORD=change-me-in-.env
GSIE_REDIS_URL=redis://:change-me-in-.env@localhost:6379/0
GSIE_REDIS_MAX_CONNECTIONS=20
# Timeouts Redis (secondes) — évite les requêtes bloquantes (résilience)
GSIE_REDIS_SOCKET_TIMEOUT=5
GSIE_REDIS_CONNECT_TIMEOUT=5
# Cache TTL pour /ready (secondes)
GSIE_HEALTH_CACHE_TTL=5

# Auth — JWT RS256
GSIE_JWT_ALGORITHM=RS256
GSIE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
GSIE_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GSIE_JWT_PRIVATE_KEY_PATH=keys/private.pem
GSIE_JWT_PUBLIC_KEY_PATH=keys/public.pem
# Dev login — NEVER enable in production
GSIE_AUTH_DEV_LOGIN_ENABLED=true
GSIE_AUTH_DEV_USERNAME=admin
GSIE_AUTH_DEV_PASSWORD=change-me-in-.env
#
# Production :
#   1. Générer les clés : ./docker/generate-jwt-keys.sh
#   2. GSIE_AUTH_DEV_LOGIN_ENABLED=false
#   3. Stocker les clés dans un secret manager (Vault, AWS SM, etc.)
#   4. Monter keys/ en lecture seule dans le conteneur (docker-compose.yml)

# Observabilité — OpenTelemetry
GSIE_OTEL_ENABLED=false
GSIE_OTEL_ENDPOINT=http://localhost:4317
GSIE_OTEL_SERVICE_NAME=gsie-api
